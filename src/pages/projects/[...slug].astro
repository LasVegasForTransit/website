---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StatusPill from '../../components/StatusPill.astro';
import InitiativeChip from '../../components/InitiativeChip.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects', (entry) => !entry.id.startsWith('_'));
  const initiatives = await getCollection('initiatives');
  const initiativesById = new Map(initiatives.map((i) => [i.id, i]));
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project, initiativesById },
  }));
}

const { project, initiativesById } = Astro.props;
const { Content } = await render(project);

const dateFmt = new Intl.DateTimeFormat('en-US', {
  month: 'long',
  year: 'numeric',
});

const startLabel = dateFmt.format(project.data.startDate);
const endLabel = project.data.endDate ? dateFmt.format(project.data.endDate) : null;
---

<BaseLayout title={project.data.title} description={project.data.tldr}>
  <header class="container-page pt-20 pb-8 md:pt-28">
    <p class="eyebrow">
      <a href="/projects" class="no-underline hover:underline">← All projects</a>
    </p>
    <div class="mt-6 flex flex-wrap items-center gap-3">
      <StatusPill status={project.data.status} />
      {
        project.data.initiatives.map((slug: string) => (
          <InitiativeChip title={initiativesById.get(slug)?.data.title ?? slug} />
        ))
      }
    </div>
    <h1 class="text-display-lg mt-6">{project.data.title}</h1>
    <p class="lede mt-6 max-w-3xl">{project.data.tldr}</p>
  </header>

  <hr class="rule-thick container-page" />

  <div class="container-page py-12 grid gap-12 md:grid-cols-[2fr_1fr]">
    <article class="prose-doc max-w-none">
      <Content />
    </article>

    <aside class="md:border-l md:pl-10 md:border-rule/20 space-y-8">
      <div>
        <p class="eyebrow">Started</p>
        <p class="mt-2 text-lg font-semibold">{startLabel}</p>
        {
          endLabel && (
            <>
              <p class="eyebrow mt-4">Wrapped</p>
              <p class="mt-2 text-lg font-semibold">{endLabel}</p>
            </>
          )
        }
      </div>
      {
        project.data.contacts.length > 0 && (
          <div>
            <p class="eyebrow">Project leads</p>
            <ul class="mt-2 space-y-2">
              {project.data.contacts.map((c: { name: string; role: string }) => (
                <li>
                  <p class="font-semibold">{c.name}</p>
                  <p class="text-sm text-mute">{c.role}</p>
                </li>
              ))}
            </ul>
          </div>
        )
      }
      <div>
        <p class="eyebrow">Want to help?</p>
        <a
          href="/join"
          class="mt-3 inline-flex items-center bg-ink text-paper px-4 py-2 text-sm font-bold no-underline"
        >
          Get involved →
        </a>
      </div>
    </aside>
  </div>
</BaseLayout>
