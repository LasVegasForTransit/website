---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import PullQuote from '../components/PullQuote.astro';
import { getEntry, render } from 'astro:content';
import { site } from '../lib/site';
import { requireEntry } from '../lib/content-guard';

const aboutPage = await getEntry('pages', 'about');
requireEntry(aboutPage, 'pages', 'about');

const { Content: OriginContent } = await render(aboutPage);

const missionStatement =
  'The mission of Las Vegans for Better Transit is to advocate for world-class public transportation and supportive land use policies in the Las\u00A0Vegas metropolitan area through public education, community outreach, and coalition building.';

const pillars: Array<{ label: string; body: string }> = [
  {
    label: 'Educate',
    body: 'Help Las Vegans see the connection between how we get around, what our neighborhoods look like, and what daily life in the Valley costs in time, money, and lives.',
  },
  {
    label: 'Organize',
    body: "Build a constituency for transit that didn't exist before — riders, neighbors, business owners, students, faith communities, labor — and put it in front of the people who write the budget.",
  },
  {
    label: 'Advocate',
    body: 'Show up at the Legislature, the RTC board, municipal planning commissions, and in the press. Push for dedicated funding, transit-oriented zoning, and the projects the Valley needs.',
  },
];

const orgRows: Array<{ label: string; value: string }> = [
  { label: 'Legal name', value: site.org.legalName },
  { label: 'Address', value: site.org.address },
  { label: 'EIN', value: site.org.ein },
  { label: 'Founded', value: site.org.founded },
];

const contacts: Array<{ label: string; email: string; context: string }> = [
  {
    label: 'General',
    email: site.email.general,
    context: 'Residents, riders, anyone with a story or a question.',
  },
  {
    label: 'Press',
    email: site.email.press,
    context: 'Reporters, editors, podcasters working on a transit story.',
  },
  {
    label: 'Partnerships',
    email: site.email.partners,
    context: 'Labor, faith, business, schools — orgs whose constituents depend on transit.',
  },
];
---

<BaseLayout title="About" description={aboutPage.data.summary}>
  {/* Hero --------------------------------------------------------------- */}
  <header class="container-page pt-20 pb-12 md:pt-28 md:pb-16">
    <SectionHeader
      title="Las Vegans for Better Transit"
      lede={'A grassroots advocacy organization fighting for world-class public transit and supportive land use in the Las\u00A0Vegas Valley.'}
    />
  </header>
  <hr class="rule-thick container-page" />

  {/* § 01 / Mission ----------------------------------------------------- */}
  <section class="container-page py-20 md:py-28">
    <p class="eyebrow">§ 01 / Mission</p>
    <h2 class="text-headline-lg mt-4 max-w-4xl">{missionStatement}</h2>

    <div class="mt-16 grid gap-px bg-ink border border-ink md:grid-cols-3">
      {
        pillars.map((p) => (
          <div class="bg-paper p-8 md:p-10 flex flex-col">
            <h3 class="text-title-lg">{p.label}</h3>
            <p class="mt-4 leading-relaxed">{p.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  {/* § 02 / Origin ------------------------------------------------------ */}
  <section class="bg-ink text-paper min-h-screen flex flex-col justify-center">
    <div
      class="container-page py-20 md:py-28 grid gap-12 md:grid-cols-[1fr_1.5fr] md:gap-16 items-start"
    >
      <div>
        <p class="eyebrow text-accent-soft">§ 02 / Origin</p>
        <h2 class="text-headline-lg mt-4">An organization that didn't exist until it had to.</h2>

        <div class="mt-10 max-w-md">
          <PullQuote cite="RTC of Southern Nevada, March 2026">
            "Without a new dedicated funding source, the RTC will be forced to eliminate fifteen
            routes and reduce service across the network — affecting hundreds of thousands of riders
            by 2028."
          </PullQuote>
        </div>
      </div>

      <div class="prose-doc text-paper max-w-2xl">
        <OriginContent />
      </div>
    </div>
  </section>

  {/* § 03 / The legal entity -------------------------------------------- */}
  <section class="container-page py-20 md:py-28">
    <div class="grid gap-12 md:grid-cols-[1fr_1.5fr] md:gap-16 items-start">
      <div>
        <p class="eyebrow">§ 03 / The legal entity</p>
        <h2 class="text-headline-lg mt-4">A registered Nevada nonprofit.</h2>
        <p class="lede mt-6 max-w-md">
          Incorporated in Nevada in April 2026. Our <span class="whitespace-nowrap">501(c)(3)</span> application
          is under IRS review; contributions will become tax-deductible upon determination.
        </p>
      </div>

      <dl class="border border-ink divide-y divide-rule/15 bg-paper">
        {
          orgRows.map((row) => (
            <div class="grid grid-cols-[8rem_1fr] md:grid-cols-[10rem_1fr] items-baseline gap-4 px-6 py-4">
              <dt class="eyebrow">{row.label}</dt>
              <dd class="text-base md:text-lg font-semibold tnum">{row.value}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  {/* § 04 / Stay in touch ----------------------------------------------- */}
  <section class="container-page py-20 md:py-28 border-t-[6px] border-ink">
    <p class="eyebrow">§ 04 / Stay in touch</p>
    <h2 class="text-headline-lg mt-4 max-w-3xl">Keep up with the work.</h2>
    <p class="lede mt-6 max-w-2xl">
      The newsletter goes out from <a href="/join" class="font-semibold text-accent">Get involved</a
      >. Day-to-day, we post on
      <a href={site.social.instagram} rel="noopener" class="font-semibold text-accent">Instagram</a>
      and
      <a href={site.social.bluesky} rel="noopener" class="font-semibold text-accent">Bluesky</a>.
      For anything more specific, the inboxes below all reach a real person.
    </p>

    <div class="mt-12 grid gap-px bg-ink border border-ink md:grid-cols-3">
      {
        contacts.map((c) => (
          <a
            href={`mailto:${c.email}`}
            class="bg-paper p-8 no-underline hover:bg-ink hover:text-paper transition-colors"
          >
            <p class="eyebrow">{c.label}</p>
            <p class="mt-3 text-lg md:text-xl font-bold underline underline-offset-4 [overflow-wrap:anywhere]">
              {c.email}
            </p>
            <p class="mt-4 text-sm leading-relaxed">{c.context}</p>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
