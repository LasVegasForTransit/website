---
import { site } from '../lib/site';

interface Props {
  variant?: 'light' | 'dark';
}
const { variant = 'light' } = Astro.props;

const isPlaceholder = site.newsletter.embedUrl.includes('PLACEHOLDER');
---

<div
  class:list={[
    'border p-6 md:p-8',
    variant === 'dark' ? 'bg-ink text-paper border-ink' : 'bg-paper text-ink border-ink',
  ]}
>
  <p class="eyebrow">Newsletter</p>
  <h3 class="text-title-lg mt-3">Updates from the front lines.</h3>
  <p class="mt-4 max-w-md">
    The 2027 session is the moment. Subscribe for legislative updates, project briefs, and ways to
    show up.
  </p>
  {
    isPlaceholder ? (
      <form class="mt-6 flex flex-col sm:flex-row gap-3" onsubmit="return false;">
        <input
          type="email"
          required
          placeholder="you@example.com"
          class="flex-1 px-4 py-3 border-2 border-current bg-transparent placeholder:opacity-60 focus:outline-none"
        />
        <button class="px-6 py-3 font-bold uppercase tracking-wider bg-accent text-paper border-2 border-accent hover:bg-transparent hover:text-current transition-colors">
          Subscribe
        </button>
      </form>
    ) : (
      <iframe
        src={site.newsletter.embedUrl}
        class="mt-6 w-full h-44 border-0"
        title="Newsletter signup"
      />
    )
  }
</div>
