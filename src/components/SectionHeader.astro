---
interface Props {
  eyebrow?: string;
  title: string;
  lede?: string;
  align?: 'start' | 'center';
  level?: 1 | 2;
}

const { eyebrow, title, lede, align = 'start', level = 1 } = Astro.props;
const Tag = level === 1 ? 'h1' : 'h2';
const titleClass = level === 1 ? 'text-display-lg' : 'text-headline-lg';
const alignClass = align === 'center' ? 'text-center mx-auto' : '';
---

<div class:list={['max-w-4xl', alignClass]}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <Tag class:list={[titleClass, 'mt-4']}>{title}</Tag>
  {lede && <p class="lede mt-6 max-w-2xl" set:html={lede} />}
</div>
