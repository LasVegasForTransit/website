---
import StatusPill from './StatusPill.astro';
import InitiativeChip from './InitiativeChip.astro';

interface Props {
  href: string;
  title: string;
  status: 'active' | 'planned' | 'complete' | 'paused';
  tldr: string;
  initiatives: { title: string }[];
}
const { href, title, status, tldr, initiatives } = Astro.props;
---

<a
  href={href}
  class="lift group block border border-ink bg-paper p-6 md:p-8 no-underline hover:bg-ink hover:text-paper"
>
  <div class="flex items-start justify-between gap-4">
    <h3 class="text-title-lg flex-1">{title}</h3>
    <StatusPill status={status} />
  </div>
  <p class="mt-6 text-body-lg leading-snug text-balance">{tldr}</p>
  {
    initiatives.length > 0 && (
      <div class="mt-8 flex flex-wrap gap-2">
        {initiatives.map((i) => (
          <InitiativeChip title={i.title} />
        ))}
      </div>
    )
  }
  <p class="mt-8 text-sm font-bold uppercase tracking-wider">Read the brief →</p>
</a>
