# Las Vegans for Better Transit — environment variables
#
# Copy this file to .env.local and fill in real values.
# `pnpm bootstrap --phase env` will walk you through it interactively.
#
# All vars below are PUBLIC_-prefixed because Astro bakes them into the static
# HTML at build time. Never put secrets here.

# Newsletter (Beehiiv embed src URL)
PUBLIC_LVBT_BEEHIIV_EMBED_URL=https://embeds.beehiiv.com/PLACEHOLDER

# Donations (Givebutter, Donorbox, etc.)
PUBLIC_LVBT_DONATE_URL=https://givebutter.com/lvbt

# Social profile URLs
PUBLIC_LVBT_INSTAGRAM=https://instagram.com/lasvegasfortransit
PUBLIC_LVBT_BLUESKY=https://bsky.app/profile/lasvegasfortransit.org
